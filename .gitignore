# 环境变量（含 API Key）
.env

# IDE 配置
.vscode/
.idea/
*.swp

# 测试临时文件
test/tmp/
.pytest_cache/

# 系统文件
.DS_Store
Thumbs.db

!examples/test_reports/
!examples/test_reports/*.pdf
